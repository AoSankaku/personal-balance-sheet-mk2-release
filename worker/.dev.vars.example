# Cloudflare Workers local secrets example.
# D1 is configured through worker/wrangler.toml, so no local secret is
# required for the current default setup.
#
# Keep real values in worker/.dev.vars only; it is ignored by git.
# Do not put Binance API keys or personal finance data in this example.

# Set to true to disable /api/admin/* endpoints such as database export and
# bulk data erasure. Recommended when those operations are not needed.
DISABLE_ADMIN_API=false

