{
  "name": "@balance-sheet/worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "build": "bun run scripts/run-wrangler-with-d1.mjs deploy --dry-run",
    "deploy": "bun run scripts/run-wrangler-with-d1.mjs deploy",
    "deploy:preview": "bun run scripts/run-wrangler-with-d1.mjs versions upload",
    "wrangler:remote": "bun run scripts/run-wrangler-with-d1.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply balance-sheet-db --local",
    "db:migrate:remote": "bun run scripts/run-wrangler-with-d1.mjs d1 migrations apply balance-sheet-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  }
}
