{
  "name": "presonal-balance-sheet-mk2",
  "private": true,
  "workspaces": [
    "frontend",
    "worker",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:worker": "bun run --cwd worker dev",
    "dev:fullstack": "bun run build:frontend && bun run --cwd worker dev:fullstack",
    "build:frontend": "bun run --cwd frontend build",
    "build:worker": "bun run --cwd worker build",
    "install:all": "bun install"
  },
  "packageManager": "bun@1.3.14"
}
